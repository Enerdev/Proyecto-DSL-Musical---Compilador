DO:CORCHEA
RE:CORCHEA |

MI:BLANCA |

// ------------------------------------------------------------
// Sección 7: Bucle de repetición con alteraciones
// ------------------------------------------------------------
REPETIR (2) {
    DO:NEGRA
    FA:NEGRA
    LA:NEGRA
    DO:NEGRA |

    SIb:CORCHEA
    DO:CORCHEA
    RE:CORCHEA
    MI:CORCHEA |
} FIN

REPETIR {
    SOL:CORCHEA
    LA:CORCHEA
    SI:CORCHEA
    DO:CORCHEA |

    RE:NEGRA
    MI:NEGRA
    FA:BLANCA |
} FIN

// ------------------------------------------------------------
// Sección 8: Clímax y final extendido
// ------------------------------------------------------------
CLAVE SOL
COMPAS 4/4
INSTRUMENTO PIANO
TEMPO 120
VOLUMEN 95

DO:BLANCA
RE:BLANCA
MI:BLANCA |

FA:CORCHEA
SOL:CORCHEA
LA:CORCHEA
SI:CORCHEA |

DO:NEGRA
RE:NEGRA
MI:NEGRA
FA:NEGRA |

SOL:REDONDA |

// Cierre de la sinfonía
SILENCIO:REDONDA |
